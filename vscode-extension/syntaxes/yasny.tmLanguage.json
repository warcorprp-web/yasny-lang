{
  "scopeName": "source.yasny",
  "name": "携褋薪褘泄",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.yasny",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.yasny",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.yasny",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.line.yasny",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.yasny",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.yasny",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.yasny",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.yasny",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.yasny",
          "match": "\\b(械褋谢懈|懈薪邪褔械械褋谢懈|懈薪邪褔械|写谢褟|芯褌|写芯|锌芯|胁|锌芯泻邪|锌芯胁褌芯褉懈|褉邪蟹|锌褉械褉胁邪褌褜|锌褉芯写芯谢卸懈褌褜|胁械褉薪褍褌褜|锌芯锌褘褌泻邪|锌芯泄屑邪褌褜|胁褋械谐写邪|斜褉芯褋懈褌褜|褋芯胁锌邪写械薪懈械|泻芯谐写邪|薪邪褋谢械写褍械褌)\\b"
        },
        {
          "name": "storage.type.yasny",
          "match": "\\b(泻芯薪褋褌|锌械褉械屑)\\b"
        },
        {
          "name": "keyword.other.yasny",
          "match": "\\b(褎褍薪泻褑懈褟|泻谢邪褋褋|薪芯胁褘泄|褝褌芯|泻芯薪械褑|懈屑锌芯褉褌|褝泻褋锌芯褉褌|懈蟹|泻邪泻|蟹邪谐褉褍蟹懈褌褜)\\b"
        },
        {
          "name": "constant.language.boolean.yasny",
          "match": "\\b(写邪|薪械褌)\\b"
        },
        {
          "name": "keyword.operator.logical.yasny",
          "match": "\\b(懈|懈谢懈|薪械)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.yasny",
          "match": "\\b(胁褘胁芯写|胁胁芯写|写谢懈薪邪|写芯斜邪胁懈褌褜|褌懈锌|芯泻褉褍谐谢|褋褌褉芯泻邪|褔懈褋谢芯|泻谢褞褔懈|蟹薪邪褔械薪懈褟|芯褕懈斜泻邪|褔懈褌邪褌褜_褎邪泄谢|蟹邪锌懈褋邪褌褜_褎邪泄谢|褋褍褖械褋褌胁褍械褌_褎邪泄谢|褉邪蟹写械谢懈褌褜|褋芯械写懈薪懈褌褜|蟹邪屑械薪懈褌褜|胁械褉褏薪懈泄|薪懈卸薪懈泄|锌芯写褋褌褉芯泻邪|芯斜褉械蟹邪褌褜|薪邪褔懈薪邪械褌褋褟_褋|蟹邪泻邪薪褔懈胁邪械褌褋褟_薪邪|褋芯写械褉卸懈褌|锌芯胁褌芯褉懈褌褜|褍写邪谢懈褌褜|胁褋褌邪胁懈褌褜|屑懈薪|屑邪泻褋|褋褌械锌械薪褜|泻芯褉械薪褜|邪斜褋|写懈邪锌邪蟹芯薪|写谢褟袣邪卸写芯谐芯|褎懈谢褜褌褉|锌褉械芯斜褉邪蟹芯胁邪褌褜|薪邪泄褌懈|薪邪泄褌懈_懈薪写械泻褋|胁褋械|谢褞斜芯泄|胁蟹褟褌褜|锌褉芯锌褍褋褌懈褌褜|褉械胁械褉褋|褋芯褉褌懈褉芯胁邪褌褜|芯斜褗械写懈薪懈褌褜|褋胁械褉薪褍褌褜|褍褋褌邪薪芯胁懈褌褜|褋褍屑屑邪|蟹邪谐褉褍蟹懈褌褜)\\b"
        },
        {
          "name": "entity.name.function.yasny",
          "match": "(?<=褎褍薪泻褑懈褟\\s+)\\w+"
        },
        {
          "name": "entity.name.function.yasny",
          "match": "\\b\\w+(?=\\s*\\()"
        },
        {
          "name": "entity.name.type.class.yasny",
          "match": "(?<=泻谢邪褋褋\\s+)\\w+"
        },
        {
          "name": "entity.name.type.class.yasny",
          "match": "(?<=薪芯胁褘泄\\s+)\\w+"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "support.function.method.yasny",
          "match": "(?<=\\.)\\w+(?=\\()"
        },
        {
          "name": "keyword.operator.arithmetic.yasny",
          "match": "\\+|\\-|\\*|\\/|%"
        },
        {
          "name": "keyword.operator.comparison.yasny",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.yasny",
          "match": "="
        },
        {
          "name": "keyword.operator.spread.yasny",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.range.yasny",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.optional.yasny",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.arrow.yasny",
          "match": "=>|\\->"
        },
        {
          "name": "keyword.operator.ternary.yasny",
          "match": "\\?|:"
        }
      ]
    }
  }
}

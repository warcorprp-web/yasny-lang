конст имя = "Аня"
конст возраст = 25
вывод("Меня зовут {имя}, мне {возраст} лет")
вывод("2 + 2 = {2 + 2}")
вывод(верхний("привет"))
вывод(нижний("МИР"))
вывод(обрезать("   hello   "))
вывод(разделить("a,b,c,d", ","))
вывод(соединить(["а", "б", "в"], "-"))
вывод(заменить("Привет, мир", "мир", "Ясный"))
вывод(содержит("программирование", "грамм"))
вывод(длина("Ясный"))
вывод(подстрока("программа", 0, 4))

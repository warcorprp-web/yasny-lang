# Порядок ключей сохраняется как в исходнике
конст человек = {
    "имя": "Иван",
    "возраст": 30,
    "город": "Казань",
    "профессия": "врач",
    "хобби": "шахматы",
}

вывод(человек)
вывод(ключи(человек))
вывод(значения(человек))
вывод(json.создать(человек))

# Итерация for-in идёт в порядке вставки
для значение в человек: вывод(значение)

# Добавление новых ключей сохраняет порядок
перем словарь = {"первый": 1, "второй": 2}
словарь["третий"] = 3
словарь["четвёртый"] = 4
вывод(ключи(словарь))

# Обновление существующего ключа НЕ меняет порядок
словарь["первый"] = 100
вывод(ключи(словарь))
вывод(значения(словарь))

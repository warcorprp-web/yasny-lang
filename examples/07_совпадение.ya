# Сопоставление с образцом.

функция описать_день(номер)
    вернуть совпадение номер
        когда 1: "Понедельник"
        когда 2: "Вторник"
        когда 3: "Среда"
        когда 4: "Четверг"
        когда 5: "Пятница"
        когда 6: "Суббота"
        когда 7: "Воскресенье"
        иначе: "Неизвестный день"
    конец
конец

для i от 1 до 8
    вывод("{i}: {описать_день(i)}")
конец

конст a = [1, 2, 3, 2, 1, 4, 3]
вывод(уникальные(a))

конст b = [1, 2, 3]
конст c = [3, 4, 5]
вывод(объединение(b, c))
вывод(пересечение(b, c))
вывод(разность(b, c))
вывод(разность(c, b))

# Размер коллекций
вывод(размер([1, 2, 3, 4]))
вывод(размер({"a": 1, "b": 2, "c": 3}))

# Свернуть (reduce)
вывод(свернуть([1, 2, 3, 4, 5], (acc, x) => acc + x, 0))
вывод(свернуть([1, 2, 3, 4], (acc, x) => acc * x, 1))

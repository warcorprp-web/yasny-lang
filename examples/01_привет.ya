# Первая программа на Ясном.
# Вывод текста и работа с переменными.

вывод("Привет, мир!")

# Неизменяемая переменная объявляется через "конст"
конст имя = "Аня"
конст возраст = 25

# Интерполяция переменных в строке: фигурные скобки внутри двойных кавычек
вывод("Меня зовут {имя}, мне {возраст} лет")

# Изменяемая переменная объявляется через "перем"
перем счётчик = 0
счётчик = счётчик + 1
счётчик += 5
вывод("Счётчик: {счётчик}")

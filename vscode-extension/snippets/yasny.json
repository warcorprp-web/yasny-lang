    ],
    "description": "Spread оператор для массива"
  },
  "массив-trailing": {
    "prefix": "массив-trailing",
    "body": [
      "конст ${1:массив} = [",
      "\t${2:элемент1},",
      "\t${3:элемент2},",
      "\t${4:элемент3},  // trailing comma разрешена",
      "]"
    ],
    "description": "Массив с trailing comma"
  },
  "деструктуризация-массив": {
    "prefix": "деструкт-массив",
    "body": [
      "конст [${1:первый}, ${2:второй}, ...${3:остальные}] = ${4:массив}"
    ],
    "description": "Деструктуризация массива с rest"
  },
  "деструктуризация-объект": {
    "prefix": "деструкт-объект",
    "body": [
      "конст {\"${1:ключ}\": ${2:переменная}} = ${3:объект}"
    ],
    "description": "Деструктуризация объекта"
  },
  "optional-chaining": {
    "prefix": "optional",
    "body": [
      "${1:объект}?.${2:свойство}"
    ],
    "description": "Optional chaining (безопасный доступ)"
  },
  "сортировка-компаратор": {
    "prefix": "сортировать-компаратор",
    "body": [
      "${1:массив}.сортировать(функция(а, б)",
      "\tвозврат ${2:а > б}  // истина если нужно поменять местами",
      "конец)"
    ],
    "description": "Сортировка с пользовательским компаратором"
  },
  "класс-наследование": {
    "prefix": "класс-наследует",
    "body": [
      "класс ${1:Потомок} наследует ${2:Родитель}",
      "\tфункция инициализация(${3:параметры})",
      "\t\tродитель.инициализация(${4:аргументы})",
      "\t\t${5:// дополнительная инициализация}",
      "\tконец",
      "\t",
      "\tфункция ${6:метод}()",
      "\t\t${7:// код метода}",
      "\tконец",
      "конец"
    ],
    "description": "Класс с наследованием"
  },
  "http-сервер": {
    "prefix": "http-сервер",
    "body": [
      "функция обработчик(запрос)",
      "\tконст путь = запрос[\"путь\"]",
      "\tконст метод = запрос[\"метод\"]",
      "\t",
      "\tесли путь == \"/\"",
      "\t\tвозврат {",
      "\t\t\t\"статус\": 200,",
      "\t\t\t\"тело\": \"Привет, мир!\"",
      "\t\t}",
      "\tконец",
      "\t",
      "\tвозврат {",
      "\t\t\"статус\": 404,",
      "\t\t\"тело\": \"Не найдено\"",
      "\t}",
      "конец",
      "",
      "http_сервер(${1:8080}, обработчик)"
    ],
    "description": "HTTP сервер с обработчиком"
  },
  "читать-файл": {
    "prefix": "читать-файл",
    "body": [
      "попытка",
      "\tконст содержимое = читать_файл(\"${1:путь/к/файлу.txt}\")",
      "\t${2:// обработка содержимого}",
      "поймать ошибка",
      "\твывод(\"Ошибка чтения файла:\", ошибка)",
      "конец"
    ],
    "description": "Чтение файла с обработкой ошибок"
  },
  "json-парсинг": {
    "prefix": "json-парсинг",
    "body": [
      "попытка",
      "\tконст данные = json_разобрать(\"${1:{\\\"ключ\\\": \\\"значение\\\"}}\")",
      "\t${2:// работа с данными}",
      "поймать ошибка",
      "\твывод(\"Ошибка парсинга JSON:\", ошибка)",
      "конец"
    ],
    "description": "Парсинг JSON с обработкой ошибок"
  },
  "regex-поиск": {
    "prefix": "regex-найти",
    "body": [
      "конст совпадения = regex_найти(\"${1:паттерн}\", \"${2:текст}\")",
      "если совпадения != пусто",
      "\tдля совпадение в совпадения",
      "\t\твывод(совпадение)",
      "\tконец",
      "конец"
    ],
    "description": "Поиск по регулярному выражению"
  }
}

конст числа = [1, 2, 3, 4, 5]
вывод(длина(числа))
вывод(сумма(числа))
вывод(числа[0])
вывод(числа[-1])
вывод(числа[1:4])
вывод(числа[:2])
вывод(числа[3:])

конст чётные = фильтр(числа, x => x % 2 == 0)
вывод(чётные)

конст квадраты = преобразовать(числа, x => x * x)
вывод(квадраты)

вывод(все(числа, x => x > 0))
вывод(любой(числа, x => x > 4))

конст уник = уникальные([1, 2, 2, 3, 3, 3, 4])
вывод(уник)

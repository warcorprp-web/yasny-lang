перечисление Цвет
    красный
    зелёный
    синий
конец

вывод(Цвет.красный)
вывод(Цвет.зелёный)
вывод(Цвет.синий)

# Сравнение
конст выбор = Цвет.зелёный
если выбор == Цвет.зелёный
    вывод("это зелёный")
конец

# В match
конст имя = совпадение выбор
    когда Цвет.красный: "тревога"
    когда Цвет.зелёный: "ок"
    когда Цвет.синий: "штиль"
    иначе: "неизвестно"
конец
вывод(имя)

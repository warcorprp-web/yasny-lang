# Простой генератор
функция числа()
    выдать 1
    выдать 2
    выдать 3
конец

# Через for-in
для x в числа(): вывод(x)

# Через взять()
вывод(взять(числа(), 2))

# Бесконечный генератор + взять
функция натуральные()
    перем n = 0
    пока да
        n += 1
        выдать n
    конец
конец
вывод(взять(натуральные(), 5))

# Фибоначчи
функция фиб()
    перем a = 0
    перем b = 1
    пока да
        выдать a
        конст t = a + b
        a = b
        b = t
    конец
конец
вывод(взять(фиб(), 8))

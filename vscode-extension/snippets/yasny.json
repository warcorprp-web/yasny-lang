      "",
      "# Сумма",
      "конст сумма_всех = сумма($1)",
      "",
      "вывод(\"Отфильтрованные: {строка(отфильтрованные)}\")",
      "вывод(\"Преобразованные: {строка(преобразованные)}\")",
      "вывод(\"Сумма: {сумма_всех}\")"
    ],
    "description": "Обработка массива (фильтр, преобразование, сумма)"
  },

функция плюс(a, b)
    вернуть a + b
конец
вывод(плюс(2, 3))

функция факториал(n)
    если n <= 1: вернуть 1
    вернуть n * факториал(n - 1)
конец
вывод(факториал(5))

функция степень(основание, показатель = 2): основание * основание
вывод(степень(7))
вывод(степень(3, 5))

конст удвоить = x => x * 2
вывод(удвоить(21))

функция применить(f, x)
    вернуть f(x)
конец
вывод(применить(удвоить, 10))

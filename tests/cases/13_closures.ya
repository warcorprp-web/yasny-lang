# Замыкание: внутренняя функция помнит переменную внешней
функция счётчик_от(начало)
    перем n = начало
    функция следующий()
        n = n + 1
        вернуть n
    конец
    вернуть следующий
конец

конст f = счётчик_от(10)
вывод(f())
вывод(f())
вывод(f())

# Несколько счётчиков независимы
конст g = счётчик_от(100)
вывод(g())
вывод(f())
вывод(g())

# Замыкание в лямбде
функция умножитель(на)
    вернуть x => x * на
конец

конст удв = умножитель(2)
конст утр = умножитель(3)
вывод(удв(7))
вывод(утр(7))

класс Точка
    функция создать(x, y)
        это.x = x
        это.y = y
    конец

    функция длина()
        вернуть корень(это.x * это.x + это.y * это.y)
    конец
конец

конст p = Точка(3, 4)
вывод(p.x)
вывод(p.y)
вывод(p.длина())

класс Животное
    функция создать(имя)
        это.имя = имя
    конец

    функция голос()
        вернуть "{это.имя}: звук"
    конец
конец

класс Кот наследует Животное
    функция голос()
        вернуть "{это.имя}: мяу"
    конец
конец

класс Собака наследует Животное
    функция создать(имя, порода)
        родитель.создать(имя)
        это.порода = порода
    конец

    функция голос()
        вернуть "{это.имя} ({это.порода}): гав"
    конец
конец

конст барсик = Кот("Барсик")
конст бобик = Собака("Бобик", "Овчарка")
вывод(барсик.голос())
вывод(бобик.голос())

функция делить(a, b)
    если b == 0: бросить "деление на ноль"
    вернуть a / b
конец

попытка
    вывод(делить(10, 2))
поймать e
    вывод("ошибка: {e}")
конец

попытка
    вывод(делить(10, 0))
поймать e
    вывод("поймал: {e}")
конец

перем порядок = []
попытка
    добавить(порядок, "a")
    бросить "x"
поймать _
    добавить(порядок, "b")
всегда
    добавить(порядок, "c")
конец
вывод(порядок)

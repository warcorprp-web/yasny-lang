{
  "функция": {
    "prefix": "функция",
    "body": [
      "функция ${1:имя}(${2:параметры})",
      "\t${3:// тело функции}",
      "\tвозврат ${4:результат}",
      "конец"
    ],
    "description": "Объявление функции"
  },
  "если": {
    "prefix": "если",
    "body": [
      "если ${1:условие}",
      "\t${2:// код}",
      "конец"
    ],
    "description": "Условный оператор"
  },
  "если-иначе": {
    "prefix": "иначе",
    "body": [
      "если ${1:условие}",
      "\t${2:// код}",
      "иначе",
      "\t${3:// код}",
      "конец"
    ],
    "description": "Условный оператор с иначе"
  },
  "для": {
    "prefix": "для",
    "body": [
      "для ${1:элемент} в ${2:массив}",
      "\t${3:// код}",
      "конец"
    ],
    "description": "Цикл for-in"
  },
  "пока": {
    "prefix": "пока",
    "body": [
      "пока ${1:условие}",
      "\t${2:// код}",
      "конец"
    ],
    "description": "Цикл while"
  },
  "класс": {
    "prefix": "класс",
    "body": [
      "класс ${1:Имя}",
      "\tфункция конструктор(${2:параметры})",
      "\t\t${3:// инициализация}",
      "\tконец",
      "\t",
      "\tфункция ${4:метод}()",
      "\t\t${5:// код метода}",
      "\tконец",
      "конец"
    ],
    "description": "Объявление класса"
  },
  "совпадение": {
    "prefix": "совпадение",
    "body": [
      "конст ${1:результат} = совпадение ${2:значение}",
      "\tкогда ${3:вариант1}: ${4:результат1}",
      "\tкогда ${5:вариант2}: ${6:результат2}",
      "\tиначе: ${7:поумолчанию}",
      "конец"
    ],
    "description": "Pattern matching"
  },
  "деструкт": {
    "prefix": "деструкт",
    "body": [
      "конст [${1:a}, ${2:b}, ...${3:rest}] = ${4:массив}"
    ],
    "description": "Деструктуризация массива"
  },
  "listcomp": {
    "prefix": "listcomp",
    "body": [
      "[${1:x * 2} для ${2:x} в ${3:массив} если ${4:x > 0}]"
    ],
    "description": "List comprehension"
  },
  "лямбда": {
    "prefix": "лямбда",
    "body": [
      "${1:x} => ${2:x * 2}"
    ],
    "description": "Лямбда функция"
  },
  "импорт": {
    "prefix": "импорт",
    "body": [
      "импорт ${1:модуль} из \"${2:путь.ya}\""
    ],
    "description": "Импорт модуля"
  },
  "экспорт": {
    "prefix": "экспорт",
    "body": [
      "экспорт ${1:конст} ${2:имя} = ${3:значение}"
    ],
    "description": "Экспорт значения"
  },
  
  "вывод": {
    "prefix": "вывод",
    "body": ["вывод(${1:значение})"],
    "description": "Вывести значение в консоль"
  },
  "ввод": {
    "prefix": "ввод",
    "body": ["ввод(${1:\"Введите: \"})"],
    "description": "Получить ввод от пользователя"
  },
  "длина": {
    "prefix": "длина",
    "body": ["длина(${1:массив})"],
    "description": "Получить длину массива/строки"
  },
  "тип": {
    "prefix": "тип",
    "body": ["тип(${1:значение})"],
    "description": "Получить тип значения"
  },
  "строка": {
    "prefix": "строка",
    "body": ["строка(${1:значение})"],
    "description": "Преобразовать в строку"
  },
  "число": {
    "prefix": "число",
    "body": ["число(${1:строка})"],
    "description": "Преобразовать в число"
  },
  "округл": {
    "prefix": "округл",
    "body": ["округл(${1:число})"],
    "description": "Округлить число"
  },
  "разделить": {
    "prefix": "разделить",
    "body": ["разделить(${1:строка}, ${2:\",\"})"],
    "description": "Разделить строку на массив"
  },
  "соединить": {
    "prefix": "соединить",
    "body": ["соединить(${1:массив}, ${2:\",\"})"],
    "description": "Соединить массив в строку"
  },
  "заменить": {
    "prefix": "заменить",
    "body": ["заменить(${1:строка}, ${2:\"старое\"}, ${3:\"новое\"})"],
    "description": "Заменить подстроку"
  },
  "верхний": {
    "prefix": "верхний",
    "body": ["верхний(${1:строка})"],
    "description": "Преобразовать в верхний регистр"
  },
  "нижний": {
    "prefix": "нижний",
    "body": ["нижний(${1:строка})"],
    "description": "Преобразовать в нижний регистр"
  },
  "подстрока": {
    "prefix": "подстрока",
    "body": ["подстрока(${1:строка}, ${2:начало}, ${3:конец})"],
    "description": "Получить подстроку"
  },
  "обрезать": {
    "prefix": "обрезать",
    "body": ["обрезать(${1:строка})"],
    "description": "Удалить пробелы с краев"
  },
  "начинается_с": {
    "prefix": "начинается_с",
    "body": ["начинается_с(${1:строка}, ${2:\"префикс\"})"],
    "description": "Проверить начало строки"
  },
  "заканчивается_на": {
    "prefix": "заканчивается_на",
    "body": ["заканчивается_на(${1:строка}, ${2:\"суффикс\"})"],
    "description": "Проверить конец строки"
  },
  "содержит": {
    "prefix": "содержит",
    "body": ["содержит(${1:строка}, ${2:\"подстрока\"})"],
    "description": "Проверить наличие подстроки"
  },
  "повторить": {
    "prefix": "повторить",
    "body": ["повторить(${1:строка}, ${2:количество})"],
    "description": "Повторить строку N раз"
  },
  "добавить": {
    "prefix": "добавить",
    "body": ["добавить(${1:массив}, ${2:элемент})"],
    "description": "Добавить элемент в массив"
  },
  "удалить": {
    "prefix": "удалить",
    "body": ["удалить(${1:массив}, ${2:индекс})"],
    "description": "Удалить элемент по индексу"
  },
  "вставить": {
    "prefix": "вставить",
    "body": ["вставить(${1:массив}, ${2:индекс}, ${3:элемент})"],
    "description": "Вставить элемент по индексу"
  },
  "найти": {
    "prefix": "найти",
    "body": ["найти(${1:массив}, ${2:x => x > 0})"],
    "description": "Найти элемент по условию"
  },
  "найти_индекс": {
    "prefix": "найти_индекс",
    "body": ["найти_индекс(${1:массив}, ${2:x => x > 0})"],
    "description": "Найти индекс элемента"
  },
  "фильтр": {
    "prefix": "фильтр",
    "body": ["фильтр(${1:массив}, ${2:x => x > 0})"],
    "description": "Отфильтровать массив"
  },
  "преобразовать": {
    "prefix": "преобразовать",
    "body": ["преобразовать(${1:массив}, ${2:x => x * 2})"],
    "description": "Преобразовать элементы массива"
  },
  "дляКаждого": {
    "prefix": "дляКаждого",
    "body": ["дляКаждого(${1:массив}, ${2:x => вывод(x)})"],
    "description": "Выполнить функцию для каждого элемента"
  },
  "свернуть": {
    "prefix": "свернуть",
    "body": ["свернуть(${1:массив}, ${2:начальное}, ${3:(acc, x) => acc + x})"],
    "description": "Свернуть массив в одно значение"
  },
  "все": {
    "prefix": "все",
    "body": ["все(${1:массив}, ${2:x => x > 0})"],
    "description": "Проверить все элементы"
  },
  "любой": {
    "prefix": "любой",
    "body": ["любой(${1:массив}, ${2:x => x > 0})"],
    "description": "Проверить хотя бы один элемент"
  },
  "сортировать": {
    "prefix": "сортировать",
    "body": ["сортировать(${1:массив})"],
    "description": "Отсортировать массив"
  },
  "реверс": {
    "prefix": "реверс",
    "body": ["реверс(${1:массив})"],
    "description": "Развернуть массив"
  },
  "объединить": {
    "prefix": "объединить",
    "body": ["объединить(${1:массив1}, ${2:массив2})"],
    "description": "Объединить массивы"
  },
  "взять": {
    "prefix": "взять",
    "body": ["взять(${1:массив}, ${2:количество})"],
    "description": "Взять N элементов"
  },
  "пропустить": {
    "prefix": "пропустить",
    "body": ["пропустить(${1:массив}, ${2:количество})"],
    "description": "Пропустить N элементов"
  },
  "сумма": {
    "prefix": "сумма",
    "body": ["сумма(${1:массив})"],
    "description": "Сумма элементов массива"
  },
  "мин": {
    "prefix": "мин",
    "body": ["мин(${1:a}, ${2:b})"],
    "description": "Минимум из двух чисел"
  },
  "макс": {
    "prefix": "макс",
    "body": ["макс(${1:a}, ${2:b})"],
    "description": "Максимум из двух чисел"
  },
  "степень": {
    "prefix": "степень",
    "body": ["степень(${1:основание}, ${2:показатель})"],
    "description": "Возведение в степень"
  },
  "корень": {
    "prefix": "корень",
    "body": ["корень(${1:число})"],
    "description": "Квадратный корень"
  },
  "абс": {
    "prefix": "абс",
    "body": ["абс(${1:число})"],
    "description": "Абсолютное значение"
  },
  "случайное": {
    "prefix": "случайное",
    "body": ["случайное()"],
    "description": "Случайное число от 0 до 1"
  },
  "диапазон": {
    "prefix": "диапазон",
    "body": ["диапазон(${1:начало}, ${2:конец})"],
    "description": "Создать диапазон чисел"
  },
  "ключи": {
    "prefix": "ключи",
    "body": ["ключи(${1:объект})"],
    "description": "Получить ключи объекта"
  },
  "значения": {
    "prefix": "значения",
    "body": ["значения(${1:объект})"],
    "description": "Получить значения объекта"
  },
  "читать_файл": {
    "prefix": "читать_файл",
    "body": ["читать_файл(${1:\"путь.txt\"})"],
    "description": "Прочитать файл"
  },
  "записать_файл": {
    "prefix": "записать_файл",
    "body": ["записать_файл(${1:\"путь.txt\"}, ${2:содержимое})"],
    "description": "Записать в файл"
  },
  "существует_файл": {
    "prefix": "существует_файл",
    "body": ["существует_файл(${1:\"путь.txt\"})"],
    "description": "Проверить существование файла"
  },
  "json_разобрать": {
    "prefix": "json_разобрать",
    "body": ["json_разобрать(${1:строка})"],
    "description": "Разобрать JSON"
  },
  "json_создать": {
    "prefix": "json_создать",
    "body": ["json_создать(${1:объект})"],
    "description": "Создать JSON строку"
  },
  "regex_найти": {
    "prefix": "regex_найти",
    "body": ["regex_найти(${1:строка}, ${2:\"шаблон\"})"],
    "description": "Найти по регулярному выражению"
  },
  "regex_заменить": {
    "prefix": "regex_заменить",
    "body": ["regex_заменить(${1:строка}, ${2:\"шаблон\"}, ${3:\"замена\"})"],
    "description": "Заменить по регулярному выражению"
  },
  "regex_совпадает": {
    "prefix": "regex_совпадает",
    "body": ["regex_совпадает(${1:строка}, ${2:\"шаблон\"})"],
    "description": "Проверить совпадение с регулярным выражением"
  },
  "http_сервер": {
    "prefix": "http_сервер",
    "body": [
      "http_сервер(${1:8080}, функция(запрос)",
      "\tвозврат {\"статус\": 200, \"тело\": \"Привет!\"}",
      "конец)"
    ],
    "description": "Создать HTTP сервер"
  },
  "http_получить": {
    "prefix": "http_получить",
    "body": ["http_получить(${1:\"https://api.example.com\"})"],
    "description": "HTTP GET запрос"
  },
  "загрузить": {
    "prefix": "загрузить",
    "body": ["загрузить(${1:\"модуль.ya\"})"],
    "description": "Загрузить и выполнить файл"
  },
  "установить": {
    "prefix": "установить",
    "body": ["установить(${1:массив})"],
    "description": "Создать множество (уникальные элементы)"
  },
  "ошибка": {
    "prefix": "ошибка",
    "body": ["ошибка(${1:\"Сообщение об ошибке\"})"],
    "description": "Создать ошибку"
  }
}

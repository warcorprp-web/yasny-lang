# Тест: stack trace при ошибках в вложенных вызовах.
# Stack trace должен показать цепочку вызовов от ошибки до точки входа.

функция инверсия(x): 1 / x

функция обработать_число(n)
    вернуть инверсия(n)
конец

функция обработать_список(числа)
    конст результаты = []
    для x в числа
        добавить(результаты, обработать_число(x))
    конец
    вернуть результаты
конец

# Ошибка возникнет при делении 1/0 в функции "инверсия".
# Stack trace должен показать: инверсия → обработать_число → обработать_список
попытка
    вывод(обработать_список([2, 4, 0, 8]))
поймать ошибка
    # ошибка содержит только текст без stack trace
    вывод("поймал: " + ошибка)
конец
вывод("после поймать")

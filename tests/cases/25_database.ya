# Тест: модуль БД (SQLite).
# Проверяем создание таблицы, вставку, запрос, обновление, транзакции.

импорт бд из "бд"

конст соед = бд.открыть(":memory:")

соед.выполнить("CREATE TABLE t (id INTEGER PRIMARY KEY, имя TEXT, число INTEGER)")
соед.выполнить("INSERT INTO t (имя, число) VALUES (?, ?)", "первый", 10)
соед.выполнить("INSERT INTO t (имя, число) VALUES (?, ?)", "второй", 20)
соед.выполнить("INSERT INTO t (имя, число) VALUES (?, ?)", "третий", 30)

# Сумма через скаляр
вывод("сумма=" + строка(соед.значение("SELECT SUM(число) FROM t")))

# Запрос
для р в соед.запрос("SELECT имя FROM t ORDER BY id")
    вывод(р.имя)
конец

# Одиночная строка
конст один = соед.строка("SELECT имя, число FROM t WHERE id = ?", 2)
вывод("один=" + один.имя + ":" + строка(один.число))

# Обновление с возвратом затронутых
конст у = соед.выполнить("UPDATE t SET число = число + 1 WHERE число > ?", 15)
вывод("обновлено=" + строка(у.затронуто))

# Транзакция с откатом
попытка
    соед.транзакция(функция(тх)
        тх.выполнить("INSERT INTO t (имя, число) VALUES (?, ?)", "плохой", 999)
        бросить "ошибка"
    конец)
поймать е
    вывод("откат")
конец

# Транзакция успешная
соед.транзакция(функция(тх)
    тх.выполнить("INSERT INTO t (имя, число) VALUES (?, ?)", "хороший", 100)
конец)
вывод("всего=" + строка(соед.значение("SELECT COUNT(*) FROM t")))

соед.закрыть()

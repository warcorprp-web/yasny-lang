пусть имя = "Вася"
пусть возраст = 25

функция привет(имя)
    вывод("Привет, " + имя + "!")
конец

привет(имя)

для i от 1 до 5
    вывод("Число: " + i)
конец

функция факториал(н)
    если н <= 1
        вернуть 1
    конец
    вернуть н * факториал(н - 1)
конец

вывод("Факториал 5 = " + факториал(5))

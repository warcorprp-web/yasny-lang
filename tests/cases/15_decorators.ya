функция логировать(f)
    функция обёртка(x)
        вывод("вход: " + строка(x))
        конст результат = f(x)
        вывод("выход: " + строка(результат))
        вернуть результат
    конец
    вернуть обёртка
конец

@логировать
функция квадрат(x): x * x

вывод(квадрат(5))
вывод(квадрат(3))

# Декораторы складываются
функция дважды(f)
    функция обёртка(x)
        вернуть f(f(x))
    конец
    вернуть обёртка
конец

@дважды
функция плюс_один(x): x + 1

вывод(плюс_один(10))

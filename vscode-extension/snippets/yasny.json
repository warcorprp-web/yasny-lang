    "body": [".содержит(${1:\"подстрока\"})"],
    "description": "Проверить наличие подстроки"
  },
  
  "калькулятор": {
    "prefix": "калькулятор",
    "body": [
      "функция калькулятор()",
      "\tконст a = число(ввод(\"Первое число: \"))",
      "\tконст операция = ввод(\"Операция (+, -, *, /): \")",
      "\tконст b = число(ввод(\"Второе число: \"))",
      "\t",
      "\tконст результат = совпадение операция",
      "\t\tкогда \"+\": a + b",
      "\t\tкогда \"-\": a - b",
      "\t\tкогда \"*\": a * b",
      "\t\tкогда \"/\": a / b",
      "\t\tиначе: \"Неизвестная операция\"",
      "\tконец",
      "\t",
      "\tвывод(\"Результат: {результат}\")",
      "конец",
      "",
      "калькулятор()"
    ],
    "description": "Простой калькулятор"
  },
  
  "читать_json": {
    "prefix": "читать_json",
    "body": [
      "конст json_текст = читать_файл(${1:\"data.json\"})",

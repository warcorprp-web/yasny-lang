  },
  "http_сервер": {
    "prefix": "http_сервер",
    "body": [
      "функция обработчик(запрос)",
      "\tконст путь = запрос.путь",
      "\t",
      "\tконст ответ = совпадение путь",
      "\t\tкогда \"/\": {",
      "\t\t\t\"статус\": 200,",
      "\t\t\t\"тело\": \"Главная страница\"",
      "\t\t}",
      "\t\tкогда \"/api\": {",
      "\t\t\t\"статус\": 200,",
      "\t\t\t\"тело\": json_создать({\"сообщение\": \"API работает\"})",
      "\t\t}",
      "\t\tиначе: {",
      "\t\t\t\"статус\": 404,",
      "\t\t\t\"тело\": \"Страница не найдена\"",
      "\t\t}",
      "\tконец",
      "\t",
      "\tвозврат ответ",
      "конец",
      "",
      "http_сервер(${1:8080}, обработчик)",
      "вывод(\"Сервер запущен на http://localhost:${1:8080}\")"
    ],
    "description": "Создать HTTP сервер с роутингом"
  },
  "http_получить": {
    "prefix": "http_получить",
    "body": ["http_получить(${1:\"https://api.example.com\"})"],

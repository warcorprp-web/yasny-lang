конст слово = "Ясный"
# длина считает символы Юникода, а не байты
вывод(длина(слово))
вывод(длина("Привет"))

# Перебор символов: for-in идёт правильно по UTF-8
для буква в "Ясный"
    вывод(буква)
конец

# Конкатенация и интерполяция с кириллицей
конст имя = "Аня"
конст возраст = 25
вывод("{имя}, {возраст} лет")

# Регистр для кириллицы
вывод(верхний("привет"))
вывод(нижний("МИР"))

# Содержит для кириллицы
вывод(содержит("программирование", "грамм"))
вывод(содержит("Ясный язык", "Я"))

# Реверс работает по символам
вывод(длина("ёлочка"))

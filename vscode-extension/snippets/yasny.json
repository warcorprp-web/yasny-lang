  },
  "сумма": {
    "prefix": "сумма",
    "body": ["сумма(${1:массив})"],
    "description": "Сумма элементов массива"
  },
  "мин": {
    "prefix": "мин",
    "body": ["мин(${1:a}, ${2:b})"],

    ],
    "description": "HTTP GET запрос к API"
  },
  
  "обработка_массива": {
    "prefix": "обработка_массива",
    "body": [
      "конст ${1:числа} = [${2:1, 2, 3, 4, 5}]",
      "",
      "# Фильтрация",
      "конст отфильтрованные = фильтр($1, х => ${3:х > 2})",

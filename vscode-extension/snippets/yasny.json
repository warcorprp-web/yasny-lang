{
  "функция": {
    "prefix": "функция",
    "body": [
      "функция ${1:имя}(${2:параметры})",
      "\t# тело функции",
      "\tвернуть ${3:результат}",
      "конец"
    ],
    "description": "Объявление функции"
  },
  "функция-короткая": {
    "prefix": "функцияк",
    "body": [
      "функция ${1:имя}(${2:параметры}): ${3:выражение}"
    ],
    "description": "Короткая (inline) форма функции"
  },
  "лямбда": {
    "prefix": "лямбда",
    "body": [
      "${1:параметр} => ${2:выражение}"
    ],
    "description": "Лямбда-функция"
  },
  "если": {
    "prefix": "если",
    "body": [
      "если ${1:условие}",
      "\t${2}",
      "конец"
    ],
    "description": "Условный оператор"
  },
  "если-иначе": {
    "prefix": "иначе",
    "body": [
      "если ${1:условие}",
      "\t${2}",
      "иначе",
      "\t${3}",
      "конец"
    ],
    "description": "Условный оператор с иначе"
  },
  "для-в": {
    "prefix": "длвф",
    "body": [
      "для ${1:элемент} в ${2:коллекция}",
      "\t${3}",
      "конец"
    ],
    "description": "Цикл по коллекции"
  },
  "для-от-до": {
    "prefix": "длото",
    "body": [
      "для ${1:i} от ${2:1} до ${3:10}",
      "\t${4}",
      "конец"
    ],
    "description": "Цикл со счётчиком"
  },
  "пока": {
    "prefix": "пока",
    "body": [
      "пока ${1:условие}",
      "\t${2}",
      "конец"
    ],
    "description": "Цикл с условием"
  },
  "класс": {
    "prefix": "класс",
    "body": [
      "класс ${1:Имя}",
      "\tфункция создать(${2:параметры})",
      "\t\tэто.${3:поле} = ${3}",
      "\tконец",
      "",
      "\tфункция ${4:метод}()",
      "\t\t${5}",
      "\tконец",
      "конец"
    ],
    "description": "Объявление класса"
  },
  "класс-наследник": {
    "prefix": "классн",
    "body": [
      "класс ${1:Имя} наследует ${2:Родитель}",
      "\tфункция создать(${3:параметры})",
      "\t\tродитель.создать(${4:аргументы})",
      "\tконец",
      "конец"
    ],
    "description": "Класс с наследованием"
  },
  "совпадение": {
    "prefix": "совпадение",
    "body": [
      "совпадение ${1:значение}",
      "\tкогда ${2:вариант1}: ${3:результат1}",
      "\tкогда ${4:вариант2}: ${5:результат2}",
      "\tиначе: ${6:по_умолчанию}",
      "конец"
    ],
    "description": "Сопоставление с образцом"
  },
  "попытка": {
    "prefix": "попытка",
    "body": [
      "попытка",
      "\t${1}",
      "поймать ${2:ошибка}",
      "\t${3}",
      "конец"
    ],
    "description": "Обработка ошибок"
  },
  "тест": {
    "prefix": "тест",
    "body": [
      "тест \"${1:название}\"",
      "\tпроверить ${2:условие}",
      "конец"
    ],
    "description": "Тест"
  },
  "вывод": {
    "prefix": "вывод",
    "body": [
      "вывод(${1:значение})"
    ],
    "description": "Вывод в консоль"
  },
  "конст": {
    "prefix": "конст",
    "body": [
      "конст ${1:имя} = ${2:значение}"
    ],
    "description": "Неизменяемая переменная"
  },
  "перем": {
    "prefix": "перем",
    "body": [
      "перем ${1:имя} = ${2:значение}"
    ],
    "description": "Изменяемая переменная"
  },
  "фильтр": {
    "prefix": "фильтр",
    "body": [
      "фильтр(${1:массив}, ${2:x} => ${3:условие})"
    ],
    "description": "Отфильтровать элементы массива"
  },
  "преобразовать": {
    "prefix": "преобразовать",
    "body": [
      "преобразовать(${1:массив}, ${2:x} => ${3:выражение})"
    ],
    "description": "Преобразовать каждый элемент массива"
  },
  "импорт": {
    "prefix": "импорт",
    "body": [
      "импорт ${1:имя} из \"${2:путь.ya}\""
    ],
    "description": "Импорт модуля"
  }
}

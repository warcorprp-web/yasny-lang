# Прерывание вложенного цикла
перем найдено = -1
для x в [1, 2, 3, 4, 5]
    для y в [10, 20, 30]
        если x == 3 и y == 20
            найдено = x * 100 + y
            прервать
        конец
    конец
конец
вывод(найдено)

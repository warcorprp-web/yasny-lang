# Тернарник — краткая форма для коротких случаев
конст x = 5
вывод(x > 0 ? "+" : "-")

# В выражении
функция знак(n): n > 0 ? "плюс" : (n < 0 ? "минус" : "ноль")
вывод(знак(7))
вывод(знак(-3))
вывод(знак(0))

# Эквивалентность с inline-если
конст a = 10
конст через_тернарник = a >= 18 ? "взрослый" : "ребёнок"
конст через_если = если a >= 18: "взрослый" иначе: "ребёнок"
вывод(через_тернарник)
вывод(через_если)
вывод(через_тернарник == через_если)

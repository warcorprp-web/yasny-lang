# Ошибки и попытки.

# Простая обработка ошибки
функция делить(a, b)
    если b == 0
        бросить "деление на ноль"
    конец
    вернуть a / b
конец

попытка
    вывод(делить(10, 2))
    вывод(делить(10, 0))
поймать ошибка
    вывод("Не получилось: {ошибка}")
конец

# Блок "всегда" выполняется в любом случае
попытка
    вывод("Пробуем")
    бросить "что-то пошло не так"
поймать e
    вывод("Поймали: {e}")
всегда
    вывод("Этот блок выполнится в любом случае")
конец
